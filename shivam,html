            readTime: '5 min read'
        }
    ]
};

// Fallback for any category
function getNewsForCategory(cat) {
    return newsData[cat] || newsData.home;
}

// Display news cards
function displayNews(category) {
    const container = document.getElementById('newsContainer');
    const articles = getNewsForCategory(category);
    container.innerHTML = '';
    
    articles.forEach((article, index) => {
        const card = document.createElement('div');
        card.className = 'news-card';
        card.innerHTML = `
            <img src="${article.image}" alt="${article.title}" loading="lazy">
            <div class="news-content">
                <h3>${article.title}</h3>
                <p>${article.summary.substring(0, 100)}...</p>
                <button class="read-more" onclick="openFullStory('${category}', ${index})">
                    Read Full Story <i class="fa fa-arrow-right"></i>
                </button>
            </div>
        `;
        container.appendChild(card);
    });
}

// OPEN FULL STORY MODAL
function openFullStory(category, index) {
    const articles = getNewsForCategory(category);
    const article = articles[index];
    
    if (!article) return;
    
    document.getElementById('modalTitle').textContent = article.title;
    document.getElementById('modalImage').src = article.image;
    document.getElementById('modalMeta').innerHTML = `
        <i class="fa fa-user"></i> ${article.author || 'News Desk'} &nbsp;|&nbsp;
        <i class="fa fa-calendar"></i> ${article.date || 'Latest Update'} &nbsp;|&nbsp;
        <i class="fa fa-clock"></i> ${article.readTime || '3 min read'}
    `;
    
    // Format full story with paragraphs
    const fullText = article.fullStory || article.summary;
    const paragraphs = fullText.split('\n').filter(p => p.trim().length > 0);
    let formattedHTML = '';
    paragraphs.forEach(para => {
        formattedHTML += `<p>${para.trim()}</p>`;
    });
    
    document.getElementById('modalText').innerHTML = formattedHTML;
    document.getElementById('storyModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

// Close modal
function closeModal() {
    document.getElementById('storyModal').style.display = 'none';
    document.body.style.overflow = 'auto';
}

// Close on outside click
window.onclick = function(event) {
    const modal = document.getElementById('storyModal');
    if (event.target === modal) {
        closeModal();
    }
}

// Category switcher
function showCategory(category, element) {
    displayNews(category);
    document.querySelectorAll('.primary-nav button').forEach(btn => {
        btn.classList.remove('active');
    });
    if (element) element.classList.add('active');
}

// Hero Slider
const slides = [
    { badge: 'BREAKING', title: 'Global Climate Summit Begins', desc: 'World leaders gather to discuss climate action and renewable energy goals.', time: '2 hours ago', image: '🌍 Climate Summit' },
    { badge: 'SPORTS', title: 'India Wins Cricket World Cup!', desc: 'Historic victory as India lifts the trophy after thrilling final match.', time: '5 hours ago', image: '🏏 World Champions' },
    { badge: 'TECH', title: 'India Launches AI Mission', desc: 'Government approves ₹10,000 crore for artificial intelligence ecosystem.', time: '3 hours ago', image: '🤖 AI Revolution' }
];

let current = 0;
function updateSlide(index) {
    document.getElementById('heroBadge').textContent = slides[index].badge;
    document.getElementById('heroTitle').textContent = slides[index].title;
    document.getElementById('heroDesc').textContent = slides[index].desc;
    document.getElementById('heroTime').textContent = '⏰ ' + slides[index].time;
    document.getElementById('heroImage').textContent = slides[index].image;
    document.querySelectorAll('.dot').forEach((dot, i) => dot.classList.toggle('active', i === index));
}

const dotsContainer = document.getElementById('sliderDots');
slides.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'dot' + (i === 0 ? ' active' : '');
    dot.onclick = () => { current = i; updateSlide(current); };
    dotsContainer.appendChild(dot);
});
setInterval(() => { current = (current + 1) % slides.length; updateSlide(current); }, 5000);
updateSlide(0);

// Initialize
displayNews('home');
</script>
</body>
</html>
