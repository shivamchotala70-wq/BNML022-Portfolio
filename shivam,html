<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ANV NewsPortal | Full Story Reader</title>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #f5f7fb;
    color: #1e293b;
}

.container {
    max-width: 1280px;
    margin: auto;
    padding: 0 20px;
}

/* ================= HEADER ================= */
.masthead {
    background: #c40000;
    padding: 20px 0;
    border-bottom: 3px solid #ffd700;
}

.logo-area {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
}

.logo {
    font-size: 34px;
    font-weight: 800;
    color: white;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
}

.logo i {
    color: #ffd700;
    margin-right: 8px;
}

.date-time {
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    padding: 8px 18px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 500;
    color: white;
}

/* ================= NAVIGATION ================= */
.primary-nav {
    background: #0f172a;
    margin-top: 20px;
    border-radius: 50px;
    overflow-x: auto;
}

.primary-nav ul {
    display: flex;
    list-style: none;
    padding: 8px 12px;
    gap: 6px;
}

.primary-nav button {
    border: none;
    background: transparent;
    color: #e2e8f0;
    padding: 10px 20px;
    border-radius: 40px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.3s ease;
    white-space: nowrap;
}

.primary-nav button:hover {
    background: #334155;
    color: white;
}

.primary-nav button.active {
    background: #c40000;
    color: white;
}

.primary-nav i {
    margin-right: 8px;
}

/* ================= HERO SLIDER ================= */
.hero-section {
    margin: 40px 0;
}

.hero-slider {
    background: linear-gradient(135deg, #0f172a, #1e293b);
    color: white;
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    flex-wrap: wrap;
}

.hero-content {
    flex: 1.2;
    padding: 45px 40px;
}

.hero-badge {
    background: #c40000;
    display: inline-block;
    padding: 6px 16px;
    border-radius: 40px;
    font-size: 12px;
    font-weight: bold;
    margin-bottom: 20px;
}

.hero-content h1 {
    font-size: 38px;
    margin-bottom: 18px;
}

.hero-content p {
    line-height: 1.7;
    margin-bottom: 20px;
}

.hero-image {
    flex: 0.9;
    min-height: 320px;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    border-left: 1px solid rgba(255,255,255,0.1);
}

.slider-dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 24px;
}

.dot {
    width: 10px;
    height: 10px;
    background: #cbd5e1;
    border-radius: 50%;
    cursor: pointer;
}

.dot.active {
    background: #c40000;
    width: 28px;
    border-radius: 20px;
}

/* ================= NEWS GRID ================= */
.news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
    gap: 28px;
    margin-top: 20px;
}

.news-card {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    transition: all 0.3s;
    cursor: pointer;
}

.news-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 30px -12px rgba(0,0,0,0.2);
}

.news-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
}

.news-content {
    padding: 22px;
}

.news-content h3 {
    margin-bottom: 12px;
    color: #0f172a;
    font-size: 1.35rem;
}

.news-content p {
    line-height: 1.6;
    color: #475569;
}

.read-more {
    display: inline-block;
    margin-top: 18px;
    background: #c40000;
    color: white;
    padding: 8px 18px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: 0.2s;
}

.read-more:hover {
    background: #0f172a;
}

/* ================= MODAL / FULL STORY POPUP ================= */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    overflow-y: auto;
}

.modal-content {
    background: white;
    max-width: 800px;
    width: 90%;
    border-radius: 28px;
    margin: 40px auto;
    animation: slideIn 0.3s ease;
    overflow: hidden;
}

@keyframes slideIn {
    from {
        transform: translateY(-50px);
        opacity: 0;
    }
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

.modal-header {
    background: #c40000;
    color: white;
    padding: 20px 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-header h2 {
    font-size: 24px;
    margin: 0;
}

.close-modal {
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    transition: 0.2s;
}

.close-modal:hover {
    transform: scale(1.1);
}

.modal-body {
    padding: 30px;
}

.modal-body img {
    width: 100%;
    max-height: 350px;
    object-fit: cover;
    border-radius: 20px;
    margin-bottom: 20px;
}

.full-story-text {
    line-height: 1.8;
    font-size: 16px;
    color: #1e293b;
}

.full-story-text p {
    margin-bottom: 16px;
}

.article-meta {
    color: #c40000;
    font-size: 14px;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 2px solid #eef2ff;
}

/* ================= SIDEBAR ================= */
.grid-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
    margin: 40px 0;
}

.sidebar-card {
    background: white;
    padding: 24px;
    border-radius: 28px;
    margin-bottom: 30px;
    box-shadow: 0 6px 14px rgba(0,0,0,0.05);
}

.sidebar-title {
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 20px;
    border-left: 5px solid #c40000;
    padding-left: 16px;
}

.trending-list {
    list-style: none;
}

.trending-list li {
    padding: 14px 0;
    border-bottom: 1px solid #eef2ff;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
}

.trending-list li:before {
    content: "🔥";
}

.trending-list li:hover {
    color: #c40000;
}

.newsletter input {
    width: 100%;
    padding: 14px;
    border: 1px solid #e2e8f0;
    border-radius: 60px;
    margin: 15px 0;
}

.btn-sub {
    width: 100%;
    border: none;
    background: #c40000;
    color: white;
    padding: 12px;
    border-radius: 60px;
    cursor: pointer;
    font-weight: bold;
}

footer {
    background: #0b1f3a;
    color: white;
    text-align: center;
    padding: 32px;
    margin-top: 60px;
}

@media (max-width: 880px) {
    .grid-layout {
        grid-template-columns: 1fr;
    }
}
</style>
</head>
<body>

<div class="masthead">
    <div class="container">
        <div class="logo-area">
            <div class="logo"><i class="fa fa-newspaper"></i> ANV NewsPortal</div>
            <div class="date-time" id="liveDate"></div>
        </div>
        <div class="primary-nav">
            <ul>
                <li><button class="active" onclick="showCategory('home',this)"><i class="fa fa-house"></i>Home</button></li>
                <li><button onclick="showCategory('india',this)"><i class="fa fa-flag"></i>India</button></li>
                <li><button onclick="showCategory('world',this)"><i class="fa fa-earth-asia"></i>World</button></li>
                <li><button onclick="showCategory('business',this)"><i class="fa fa-chart-line"></i>Business</button></li>
                <li><button onclick="showCategory('technology',this)"><i class="fa fa-microchip"></i>Tech</button></li>
                <li><button onclick="showCategory('sports',this)"><i class="fa fa-football"></i>Sports</button></li>
                <li><button onclick="showCategory('entertainment',this)"><i class="fa fa-film"></i>Entertainment</button></li>
            </ul>
        </div>
    </div>
</div>

<div class="container">
    <div class="hero-section">
        <div class="hero-slider">
            <div class="hero-content">
                <div class="hero-badge" id="heroBadge">BREAKING</div>
                <h1 id="heroTitle">Global Climate Summit Begins</h1>
                <p id="heroDesc">World leaders gather to discuss climate action and renewable energy goals.</p>
                <div id="heroTime">⏰ 2 hours ago</div>
            </div>
            <div class="hero-image" id="heroImage">🌍 Climate Summit</div>
        </div>
        <div class="slider-dots" id="sliderDots"></div>
    </div>

    <div class="grid-layout">
        <div>
            <h2 style="margin-bottom:24px;"><i class="fa fa-bolt"></i> Top Stories</h2>
            <div class="news-grid" id="newsContainer"></div>
        </div>
        <div>
            <div class="sidebar-card">
                <div class="sidebar-title"><i class="fa fa-chart-simple"></i> Trending</div>
                <ul class="trending-list" id="trendingList">
                    <li>Market reaches all-time high</li>
                    <li>India wins cricket series</li>
                    <li>AI technology trends</li>
                </ul>
            </div>
            <div class="sidebar-card newsletter">
                <div class="sidebar-title">📧 Newsletter</div>
                <input type="email" id="newsEmail" placeholder="Enter Email">
                <button class="btn-sub" onclick="alert('✅ Subscribed!')">Subscribe</button>
            </div>
        </div>
    </div>
</div>

<!-- FULL STORY MODAL -->
<div id="storyModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Full Story</h2>
            <button class="close-modal" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body" id="modalBody">
            <img id="modalImage" src="" alt="Article image">
            <div class="article-meta" id="modalMeta"></div>
            <div class="full-story-text" id="modalText"></div>
        </div>
    </div>
</div>

<footer>
    <p>© 2026 ANV NewsPortal | Full Stories with Detailed Coverage</p>
</footer>

<script>
// Live Date
document.getElementById('liveDate').textContent = new Date().toLocaleDateString('en-US', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});

// ================= COMPLETE NEWS DATA WITH FULL STORIES =================
const newsData = {
